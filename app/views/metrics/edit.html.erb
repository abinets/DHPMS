<%= content_for :title, t(".title") %>

<div class="container mx-auto max-w-2xl px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="h2">
      <%= link_to Metric.model_name.human(count: 2), metrics_path, class: "text-gray-900 dark:text-white hover:text-primary-500 dark:hover:text-primary-400" %>
      <span class="text-gray-400 dark:text-gray-600 font-light mx-2">\</span>
      <%= t(".title") %>
    </h1>
    <%= button_to t("scaffold.actions.destroy"), @metric, method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: t("are_you_sure") } } %>
  </div>

  <div class="bg-white dark:bg-gray-900 dark:border dark:border-gray-700 rounded-lg shadow-md p-6 md:p-8">
    <%= render "form", metric: @metric %>
  </div>
</div>
