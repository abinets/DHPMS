<%= content_for :title, t(".title") %>
<%= turbo_stream_from :metrics %>

<div class="container mx-auto max-w-4xl">
  <div class="flex items-center justify-between mb-6 mt-6">
    <h1 class="h2"><%= t(".title") %></h1>
    <%= link_to t("scaffold.new.title", model: Metric.model_name.human), new_metric_path, class: "btn btn-primary" %>
  </div>

  <%# Sorting links - kept simple for now, can be enhanced with dropdowns if needed %>
  <div class="text-sm font-medium mb-4">
    <span class="text-gray-500 dark:text-gray-300/75">Sort by:</span>
    <%= sortable @metrics, :value, t(".value"), class: "text-gray-700 dark:text-gray-300 hover:text-primary-500 dark:hover:text-primary-400 mr-2" %>
    <%= sortable @metrics, :time, t(".time"), class: "text-gray-700 dark:text-gray-300 hover:text-primary-500 dark:hover:text-primary-400" %>
  </div>

  <div id="<%= "metrics" if first_page? %>" class="mt-6 flex flex-col rounded-lg divide-y divide-gray-200 bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-700 dark:divide-gray-700">
    <%= render partial: "metrics/metric", collection: @metrics, as: :metric, cached: true %>

    <% if @metrics.empty? %>
      <div class="p-8 text-center text-gray-500 dark:text-gray-400">
        <p class="mb-4 text-xl font-semibold"><%= t(".empty_state.title") %></p>
        <p class="mb-4"><%= t(".empty_state.description") %></p>
        <%= link_to t("scaffold.new.title", model: Metric.model_name.human), new_metric_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-8 text-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
