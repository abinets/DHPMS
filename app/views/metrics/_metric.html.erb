<div id="<%= dom_id metric %>" class="p-4 lg:p-6 hover:bg-gray-50 dark:hover:bg-gray-800/50">
  <div class="flex items-center justify-between">
    <div class="flex-grow">
      <div class="mb-1">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= Metric.human_attribute_name(:value) %>:</span>
        <span class="ml-1 text-gray-900 dark:text-gray-100"><%= metric.value %></span>
      </div>
      <div>
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= Metric.human_attribute_name(:time) %>:</span>
        <span class="ml-1 text-gray-900 dark:text-gray-100"><%= l metric.time, format: :long %></span>
      </div>
    </div>

    <div class="flex items-center space-x-2 ml-4">
      <%= link_to t("scaffold.actions.show"), metric, class: "btn btn-sm btn-white" %>
      <%= link_to t("scaffold.actions.edit"), edit_metric_path(metric), class: "btn btn-sm btn-white" %>
      <%= button_to t("scaffold.actions.destroy"), metric, method: :delete, class: "btn btn-sm btn-danger", form: { data: { turbo_confirm: t("are_you_sure") } } %>
    </div>
  </div>
</div>
