<%= form_with(model: metric, html: { class: "space-y-6" }) do |form| %>
  <%= render "shared/error_messages", resource: form.object %>

  <div>
    <%= form.label :value, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.number_field :value, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 dark:focus:border-primary-500 dark:focus:ring-primary-500 sm:text-sm" %>
  </div>

  <div>
    <%= form.label :time, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.datetime_field :time, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 dark:focus:border-primary-500 dark:focus:ring-primary-500 sm:text-sm" %>
  </div>

  <div class="flex items-center justify-end space-x-3 pt-3">
    <% if form.object.new_record? %>
      <%= link_to t("cancel"), metrics_path, class: "btn btn-white" %>
    <% else %>
      <%= link_to t("cancel"), metric_path(metric), class: "btn btn-white" %>
    <% end %>
    <%= form.button button_text(form.send(:submit_default_value)), class: "btn btn-primary" %>
    <% end %>
  </div>
<% end %>
